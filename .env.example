###############################################################################
# CyberVault environment template
#
# Copy this file to `.env`, then fill in the values for your setup.
# Never commit your real `.env` file. It may contain API keys, passwords,
# OAuth tokens, webhook URLs, and private server details.
###############################################################################

# App binding
APP_BIND=127.0.0.1
APP_PORT=7000
APP_DATA_DIR=./data
APP_LOGS_DIR=./logs

# Authentication
AUTH_ENABLED=true
LOCALHOST_BYPASS=false
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=change-this-password
SECURE_COOKIES=false
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# LLM providers
LLM_HOST=host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Optional research/model overrides
RESEARCH_LLM_ENDPOINT=
EMBEDDING_URL=
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
FASTEMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
FASTEMBED_CACHE_PATH=

# Built-in services
SEARXNG_INSTANCE=http://searxng:8080
SEARXNG_SECRET=change-this-random-secret
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
DATABASE_URL=sqlite:///./data/app.db

# Optional web search providers
DATA_BRAVE_API_KEY=
GOOGLE_API_KEY=
GOOGLE_PSE_CX=
TAVILY_API_KEY=
SERPER_API_KEY=

# Runtime workers and limits
CLEANUP_INTERVAL_HOURS=24
ODYSSEUS_INPROCESS_POLLERS=1
ODYSSEUS_INPROCESS_TASKS=1
ODYSSEUS_SCRIPT_HOST=localhost
ODYSSEUS_CHAT_UPLOAD_MAX_BYTES=10485760
ODYSSEUS_GALLERY_UPLOAD_MAX_BYTES=104857600
ODYSSEUS_GALLERY_TRANSFORM_UPLOAD_MAX_BYTES=26214400
ODYSSEUS_MEMORY_IMPORT_MAX_BYTES=10485760
ODYSSEUS_PERSONAL_UPLOAD_MAX_BYTES=26214400
ODYSSEUS_EMAIL_COMPOSE_UPLOAD_MAX_BYTES=26214400
ODYSSEUS_STT_MAX_AUDIO_BYTES=26214400
ODYSSEUS_ICS_MAX_BYTES=10485760

# Docker user mapping
PUID=1000
PGID=1000

# Optional integrations
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
